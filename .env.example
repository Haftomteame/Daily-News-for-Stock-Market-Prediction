# Stockage lakehouse : local (defaut) ou HDFS
STORAGE_BACKEND=local
# LOCAL_STORAGE_ROOT=chemin/optionnel  (defaut: racine projet)

# HDFS (STORAGE_BACKEND=hdfs) — Docker : docker compose --profile hdfs up -d
# HDFS_NAMENODE=namenode          # dans Docker
# HDFS_NAMENODE=localhost         # Python local (Windows/Mac)
# HDFS_WEB_PORT=9870
# HDFS_DATANODE_HOST=localhost         # Python local (Windows/Mac)
# HDFS_DATANODE_HOST=datanode          # dans Docker
# HDFS_DATANODE_WEB_PORT=9864
# HDFS_PORT=8020
# HDFS_USER=hdfs
# HDFS_BASE_PATH=/datax

# PostgreSQL (warehouse) — donnees structurees (mode replace)
# PGHOST=postgres
# PGPORT=5432
# PGDATABASE=wherehouse
# PGUSER=datax
# PGPASSWORD=10102026Ha

# Dolt (ubuntu-box : clones sous /data)
# DOLT_ROOT=/data
# DOLT_EXPORT_DIR=/data/exports
# scripts/export_dolt_rates.py — export CSV (depot rates)
# scripts/export_dolt_earnings.py — export CSV (depot earnings)
# scripts/dolt_to_postgres.py — import vers PostgreSQL
# scripts/dolt_rates_to_postgres.py — import rates -> PostgreSQL
# scripts/dolt_options_to_postgres.py — import options -> PostgreSQL
# scripts/dolt_earnings_to_postgres.py — import earnings -> PostgreSQL

# Airflow (profil docker compose airflow)
# AIRFLOW_FERNET_KEY=cle-fernet-base64
# AIRFLOW_ADMIN_USER=admin
# AIRFLOW_ADMIN_PASSWORD=admin
# GOLD_ENGINE=spark
# PIPELINE_MASSIVE=true
# PIPELINE_REFRESH_BRONZE=false
# PIPELINE_PREDICT_YEAR=2026
# AIRFLOW_DAG_SCHEDULE=@daily

# Finnhub WebSocket (streaming OHLCV journalier) — https://finnhub.io/
FINNHUB_TOKEN=votre-api-key
FINNHUB_SYMBOL=DIA
FINNHUB_BUCKET_MODE=minute
FINNHUB_BUCKET_SEC=60

# Massive REST API — Dashboard > Keys > Accessing the API
MASSIVE_API_KEY=votre-api-key

# Massive Flat Files S3 — Dashboard > Keys > Flat Files (Day Aggregates = Starter+)
MASSIVE_S3_ACCESS_KEY=votre-access-key-id
MASSIVE_S3_SECRET_KEY=votre-secret-access-key
MASSIVE_S3_ENDPOINT=https://files.massive.com
MASSIVE_S3_BUCKET=flatfiles

# Reddit API (optionnel, mode --praw uniquement) — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=votre-client-id
REDDIT_CLIENT_SECRET=votre-client-secret
REDDIT_USER_AGENT=stock-news-fetcher/1.0
